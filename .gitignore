# ---- KiCad ----
# Autosave e backup
_autosave-*
*-backups/
*.kicad_sch-bak
*.kicad_pcb-bak
*-save.kicad_sch
*-save.kicad_pcb
*.bak
*~

# Lock e cache (rigenerabili)
*.lck
~*.lck
fp-info-cache

# Rescue e netlist esportate
*-rescue.kicad_sym
*-rescue.lib
*-rescue.dcm
*.net

# ---- Plugin kicad-jlcpcb-tools (database/cache locale, rigenerabile) ----
**/jlcpcb/
.jlcpcb/

# ---- Output di fabbricazione (rigenerabili) ----
